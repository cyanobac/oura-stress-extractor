# Copy to .env and fill in before `docker compose up` in production.

# Production TLS mode (the domain lives in CADDY_SITE_ADDR):
# - `CADDY_SITE_ADDR=https://stress.example.com`
# - `CADDY_TLS_SNIPPET=tls_origin`
CADDY_SITE_ADDR=https://stress.example.com
CADDY_TLS_SNIPPET=tls_origin

# Salt for hashing client IPs in the request log. Keep it constant across
# restarts (a random new salt makes every redeploy look like all-new visitors)
# and never commit the real value. Generate one with e.g.
#   python -c "import secrets; print(secrets.token_hex(16))"
REQUEST_LOG_SALT=

# Contact address for the footer "Contact" mailto link. Baked into the frontend
# bundle at build time; leave empty to hide the link entirely.
CONTACT_EMAIL=
